# Clave de la API de Gemini (requerido para resúmenes de NLP y análisis de marca)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Clave de la API de TrendsMCP (requerido para recolección de tendencias crudas)
# Copia la clave de tu cuenta de TrendsMCP
TRENDSMCP_API_KEY=tu_trendsmcp_api_key_aqui

# Credenciales de Reddit PRAW (requerido para recolección de comentarios/contexto)
# Regístrate en reddit.com/prefs/apps como script app para obtenerlas
REDDIT_CLIENT_ID=tu_reddit_client_id_aqui
REDDIT_CLIENT_SECRET=tu_reddit_client_secret_aqui
REDDIT_USER_AGENT=trend-listening-agent-v1.0
